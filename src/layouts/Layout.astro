---
import "@/styles/global.css"
import "sonner/dist/styles.css" // https://github.com/withastro/astro/issues/9350

import { ClientRouter } from "astro:transitions"
import Navigator, { type NavigatorLink } from "@/components/Navigator"
import { Toaster } from "@/components/ui/sonner"

const navLinks: NavigatorLink[] = [
	{
		label: "Home",
		path: "",
	},
	{
		label: "About",
		path: "about",
	},
]

const { title } = Astro.props
---

<html lang="en" class="light">
	<head>
		<base href={import.meta.env.BASE_URL} />
		<meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link rel="icon" type="image/png" href="favicon.png" />
		<ClientRouter />
	</head>
	<body>
		<Toaster position="top-center" theme="light" transition:persist client:load />
		<div class="flex flex-col min-h-screen">
			<header class="sticky top-0 z-50 flex justify-center">
				<Navigator links={navLinks} transition:persist client:load />
			</header>
			<main class="grow flex flex-col items-center gap-y-8">
				<slot />
			</main>
			<footer class="bg-gradient-to-t from-accent to-transparent py-16">
				<div class="flex flex-col sm:flex-row items-center sm:justify-center gap-2 text-accent-foreground text-sm">
					<div>
						&copy; {new Date().getFullYear()} Side Trails Software Development
					</div>
					<div class="max-sm:hidden">-</div>
					<div>
						Spencer Haan
					</div>
				</div>
				</div>
			</footer>
		</div>
	</body>
</html>
