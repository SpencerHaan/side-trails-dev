---
import { cn } from '@/lib/utils'

interface Props {
  class?: string
}

const { class: className = "" } = Astro.props
---

<div class={cn(
  "m-6",
  className
)}>
  <div class="border border-primary relative size-full rounded-full bg-accent text-primary">
    <div class="absolute inset-0 flex items-center justify-center -z-10">
      <div class="relative size-28 rounded-sm bg-secondary text-secondary font-mono rotate-45">
        <span class="absolute -left-3 -top-5 -rotate-45">N</span>
        <span class="absolute -right-3 -top-5 -rotate-45">E</span>
        <span class="absolute -right-3 -bottom-5 -rotate-45">S</span>
        <span class="absolute -left-3 -bottom-5 -rotate-45">W</span>
      </div>
    </div>
    <div class="absolute inset-0 m-2 flex justify-center items-center">
      <hr class="border-primary border-dashed w-full rotate-[-36deg]" />
    </div>
    <div class="absolute inset-0 m-2 flex justify-center items-center">
      <hr class="border-primary border-dashed w-full rotate-36" />
    </div>
    <div class="absolute left-1/5 top-1/2 -translate-1/2">
      <slot name="icon-left" />
    </div>
    <div class="absolute left-4/5 top-1/2 -translate-1/2">
      <slot name="icon-right" />
    </div>
    <div class="absolute left-1/2 top-1/4 -translate-1/2">
      <slot name="icon-top" />
    </div>
    <div class="absolute left-1/2 top-3/4 -translate-1/2">
      <slot name="icon-bottom" />
    </div>
  </div>
</div>
