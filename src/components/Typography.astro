---
import { cn } from "@/lib/utils"

interface Props {
  class?: string
}

const props = Astro.props
---

<div class={cn(
  "max-w-none prose prose-sm prose-blockquote:text-foreground prose-p:text-foreground lg:prose-base",
  "prose-headings:text-foreground prose-p:text-foreground prose-blockquote:text-foreground prose-a:text-muted-foreground",
  "prose-headings:scroll-m-20 prose-headings:font-semibold prose-headings:tracking-tight",
  "prose-h1:text-center prose-h1:text-4xl prose-h1:font-extrabold prose-h1:text-balance",
  "prose-h2:border-b prose-h2:border-dashed prose-h2:pb-2 prose-h2:text-3xl prose-h2:first:mt-0 prose-h2:text-primary prose-h2:font-heading prose-h2:font-bold",
  "prose-h3:text-2xl prose-h4:text-xl",
  "prose-h5:text-lg prose-h5:font-normal prose-h5:font-mono",
  "prose-h6:text-base prose-h6:text-muted-foreground",
  "prose-p:leading-7 prose-p:not-first:mt-6",
  "prose-a:text-primary prose-a:hover:text-primary/75 prose-a:transition-colors",
  "prose-blockquote:mt-6 prose-blockquote:border-l-2 prose-blockquote:border-l-secondary prose-blockquote:pl-6 prose-blockquote:italic",
  props.class
)}>
  <slot />
</div>
