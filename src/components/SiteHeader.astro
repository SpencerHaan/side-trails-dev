---
import { cn } from "@/lib/utils"
import { DesktopNav, MobileNav } from "@/components/navs"

const navItems: { label: string, href: string }[] = [
	{
		label: "Home",
		href: "/",
	},
	{
		label: "About",
		href: "/about",
	},
]

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<header class={cn(
  "relative w-full max-w-5xl mx-auto",
  className
)}>
  <MobileNav items={navItems} class="flex sm:hidden m-2" client:visible />
  <DesktopNav items={navItems} class="hidden sm:flex m-2" client:visible />
</header>
