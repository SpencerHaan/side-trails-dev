---
interface Props {
  id: string
  title?: string
  subtitle?: string | string[]
}

const { id, title, subtitle } = Astro.props
---

<div id={id} class="mx-auto max-w-7xl w-full">
    <div class="flex flex-col gap-2 md:gap-3">
      {title
        ? <div class="text-center text-2xl md:text-3xl">{title}</div>
        : null
      }
      { subtitle
        ? <div class="pb-2 text-xs md:text-base text-center text-muted-foreground">
            { Array.isArray(subtitle)
                ? subtitle.map((s) => <p>{s}</p>)
                : subtitle
            }
          </div>
        : null
      }
      <slot />
    </div>
</div>
